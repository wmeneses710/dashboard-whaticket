# --- Base de datos (la misma que llena el ETL) ---
# En dev: copia local restaurada del dump de EasyPanel.
# En prod (EasyPanel): host interno del servicio Postgres.
DATABASE_URL=postgresql://whaticket:whaticket@localhost:5432/whaticket

# --- Ollama (LLM local para el scoring semantico) ---
# En dev: tu Ollama local. En prod: Ollama del host de EasyPanel.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:4b

# --- API / dashboard ---
API_HOST=0.0.0.0
API_PORT=8080
LOG_LEVEL=INFO
