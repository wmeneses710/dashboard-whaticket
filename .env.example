# ── Base de datos (Postgres del ETL de Whaticket) ──
# EN PROD: apuntar a la BD del ETL. NO usar la 'db' del docker-compose (está vacía).
DATABASE_URL=postgresql://usuario:password@host:5432/whaticket

# ── Ollama (motor del scoring de calidad) ──
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3.5:4b
# Ollama compartido de la org (Cloudflare, detrás de proxy con token).
# src/llm.py ya envía Authorization: Bearer <OLLAMA_TOKEN> (commit 207d618),
# así que apuntar acá SÍ funciona: descomentá y cargá el token.
# Nota: USE_OPENAI es variable del contenedor compartido, no del scorer;
# nuestro scorer siempre habla Ollama, así que acá no aplica.
#OLLAMA_URL=https://ollama-internal.zgames.store
#OLLAMA_MODEL=qwen3:14b
#OLLAMA_TOKEN=

# ── Worker de scoring ──
SCORING_ENABLED=false
SCORING_ACCOUNTS=sistemas,datos
SCORING_BATCH_SIZE=20
SCORING_POLL_SECONDS=60

# ── Cuadros del dashboard ──
CHARTS_WINDOW_MONTHS=12

# ── API ──
API_HOST=0.0.0.0
API_PORT=8080
LOG_LEVEL=INFO